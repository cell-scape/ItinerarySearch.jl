{
  "_comment": "Exhaustive SearchConfig exemplar. Every field below is set to its compiled-in default value; delete a key to rely on the default (same effect) or change the value to override. Companion prose reference lives at config/README.md.",
  "store": {
    "backend": "duckdb",
    "path": ":memory:"
  },
  "data": {
    "ssim": "data/input/uaoa_ssim.new.dat",
    "mct": "data/input/MCTIMFILUA.DAT",
    "airports": "data/input/mdstua.txt",
    "regions": "data/input/REGIMFILUA.DAT",
    "aircrafts": "data/input/aircraft.txt",
    "oa_control": "data/input/oa_control_table.csv",
    "seats": "data/input/seats_ua.txt.DAT",
    "classmap": "data/input/classmaptable.txt",
    "serviceclass": "data/input/servclasstable.dat",
    "constraints": "data/output"
  },
  "schedule": {
    "leading_days": 1,
    "trailing_days": 1,
    "max_days": 1
  },
  "search": {
    "max_stops": 2,
    "max_connection_minutes": 480,
    "max_elapsed_minutes": 1440,
    "circuity_check_scope": "both",
    "scope": "all",
    "interline": "codeshare",
    "allow_roundtrips": false,
    "distance_formula": "haversine",
    "maft_enabled": true,
    "interline_dcnx_enabled": true,
    "crs_cnx_enabled": true
  },
  "mct_behaviour": {
    "mct_cache_enabled": true,
    "mct_serial_ascending": false,
    "mct_codeshare_mode": "both",
    "mct_schengen_mode": "sch_then_eur",
    "mct_suppressions_enabled": true
  },
  "graph": {
    "export_path": "data/output",
    "import_path": "data/output"
  },
  "output": {
    "metrics_level": "full",
    "event_log_enabled": false,
    "event_log_path": "data/output/events.jsonl",
    "log_level": "info",
    "log_json_path": "data/output/info_log.jsonl",
    "log_stdout_json": false,
    "output_formats": [
      "json",
      "yaml",
      "csv"
    ]
  },
  "mct_audit": {
    "enabled": true,
    "detail": "summary",
    "output_path": "data/output/mct_audit.log",
    "max_connections": 0,
    "max_candidates": 10
  }
}