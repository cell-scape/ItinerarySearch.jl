{
  "store": {
    "backend": "duckdb",
    "path": ":memory:"
  },
  "data": {
    "ssim": "data/input/uaoa_ssim.new.dat",
    "mct": "data/input/MCTIMFILUA.DAT",
    "airports": "data/input/mdstua.txt",
    "regions": "data/input/REGIMFILUA.DAT",
    "aircrafts": "data/input/aircraft.txt",
    "seats": "data/input/seats_ua.txt.DAT",
    "classmap": "data/input/classmaptable.txt",
    "serviceclass": "data/input/servclasstable.dat",
    "oa_control": "data/input/oa_control_table.csv"
  },
  "search": {
    "max_stops": 3,
    "max_connection_minutes": 480,
    "max_elapsed_minutes": 1440,
    "circuity_factor": 2.0,
    "circuity_extra_miles": 500.0,
    "scope": "all",
    "interline": "codeshare"
  },
  "schedule": {
    "max_days": 1,
    "trailing_days": 0
  },
  "output": {
    "format": "json",
    "compression": "zstd",
    "include_flight_id": true,
    "include_dei_fields": true
  }
}